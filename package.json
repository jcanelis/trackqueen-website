{
  "name": "trackqueen.app",
  "private": true,
  "description": "Marketing website for TrackQueen.",
  "version": "1.0.0",
  "license": "0BSD",
  "scripts": {
    "build": "npm run  && gatsby build",
    "develop": "gatsby develop",
    "format": "prettier --write *.{js,json} src/**/*.js",
    "lint": "eslint .",
    "start": "gatsby develop",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "fonts:fetch": "wget -O fonts.zip $SECRET_FONTS_URL; unzip -j fonts.zip -d ./static/fonts/; rm fonts.zip",
    "test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\" && exit 1"
  },
  "dependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "babel-plugin-styled-components": "^2.1.4",
    "gatsby": "^5.16.1",
    "gatsby-plugin-image": "^3.16.0",
    "gatsby-plugin-sharp": "^5.16.0",
    "gatsby-plugin-sitemap": "^6.16.0",
    "gatsby-plugin-styled-components": "^6.16.0",
    "gatsby-remark-embed-video": "^3.2.1",
    "gatsby-remark-images-contentful": "^6.16.0",
    "gatsby-remark-responsive-iframe": "^6.16.0",
    "gatsby-source-contentful": "^8.17.0",
    "gatsby-source-filesystem": "^5.16.0",
    "gatsby-transformer-remark": "^6.16.0",
    "gatsby-transformer-sharp": "^5.16.0",
    "gatsby-transformer-sqip": "^5.16.0",
    "globals": "^17.5.0",
    "netlify-cli": "^24.11.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "styled-components": "^6.4.0"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.8.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jcanelis/trackapp"
  }
}
